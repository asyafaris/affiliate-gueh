{
  "permissions": {
    "allow": [
      "PowerShell(node --version)",
      "PowerShell(npm --version)",
      "PowerShell(npm list --depth=0 2>&1)",
      "PowerShell(npx prisma generate 2>&1)",
      "PowerShell(npx prisma db execute --stdin 2>&1)",
      "PowerShell(npx prisma db execute --stdin --schema prisma\\\\schema.prisma 2>&1)",
      "PowerShell(npm run build 2>&1)"
    ]
  }
}
